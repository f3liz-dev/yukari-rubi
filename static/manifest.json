{
  "manifest_version": 2,
  "name": "Yukari Rubi",
  "version": "0.3.0",
  "icons": {
    "16": "icons/kaguyaIcons_display_16.png",
    "32": "icons/kaguyaIcons_display_32.png",
    "48": "icons/kaguyaIcons_display_48.png",
    "96": "icons/kaguyaIcons_display_96.png",
    "128": "icons/kaguyaIcons_display_128.png"
  },
  "description": "Add furigana reading aids to Japanese text on web pages using Sudachi morphological analysis",
  "permissions": ["storage", "tabs"],
  "background": {
    "page": "background.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_icon": {
      "16": "icons/kaguyaIcons_disabled_16.png",
      "32": "icons/kaguyaIcons_disabled_32.png",
      "48": "icons/kaguyaIcons_disabled_48.png"
    },
    "default_popup": "popup.html",
    "default_title": "Yukari Rubi"
  },
  "commands": {
    "toggle-furigana": {
      "suggested_key": {
        "default": "Alt+F"
      },
      "description": "Toggle furigana on the current page"
    }
  },
  "content_security_policy": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'",
  "web_accessible_resources": ["wasm/*", "dict/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "yukari-rubi@f3liz.casa",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
